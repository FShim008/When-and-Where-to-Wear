# ---- Unity generated (regenerable cache — never commit) ----
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
[Mm]emoryCaptures/
[Rr]ecordings/

# Asset meta files must be kept even when other ignores are broad
!/[Aa]ssets/**/*.meta

# ---- IDE / build tool files (regenerated by Unity) ----
.vs/
.vscode/
.idea/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db
*.pidb.meta
*.pdb.meta
*.mdb.meta

# ---- Build / packaging artifacts ----
*.apk
*.aab
*.app
*.unitypackage
crashlytics-build.properties
sysinfo.txt

# Packed Addressables
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# Auto-generated Android streaming assets
/[Aa]ssets/[Ss]treamingAssets/aa.meta
/[Aa]ssets/[Ss]treamingAssets/aa/*

# ---- Project-specific artifacts ----
UpgradeLog.htm
TestResults*.xml
